--- a/src/x11_window.c
+++ b/src/x11_window.c
@@ -56,6 +56,17 @@
 
 #define _GLFW_XDND_VERSION 5
 
+extern int _glfwLinuxscreenGetCursorCenter(void* window, double* xpos, double* ypos)
+    __attribute__((weak));
+
+static GLFWbool getLinuxscreenCursorCenter(_GLFWwindow* window, double* xpos, double* ypos)
+{
+    if (!_glfwLinuxscreenGetCursorCenter)
+        return GLFW_FALSE;
+
+    return _glfwLinuxscreenGetCursorCenter(window, xpos, ypos) ? GLFW_TRUE : GLFW_FALSE;
+}
+
 // Wait for event data to arrive on the X11 display socket
 // This avoids blocking other threads via the per-display Xlib lock that also
 // covers GLX functions
@@ -2865,10 +2876,23 @@
     {
         if (mode == GLFW_CURSOR_DISABLED)
         {
-            _glfwGetCursorPosX11(window,
-                                 &_glfw.x11.restoreCursorPosX,
-                                 &_glfw.x11.restoreCursorPosY);
-            _glfwCenterCursorInContentArea(window);
+            double centerX = 0.0;
+            double centerY = 0.0;
+            const GLFWbool haveLinuxscreenCenter =
+                getLinuxscreenCursorCenter(window, &centerX, &centerY);
+            if (haveLinuxscreenCenter)
+            {
+                _glfw.x11.restoreCursorPosX = centerX;
+                _glfw.x11.restoreCursorPosY = centerY;
+                _glfwSetCursorPosX11(window, centerX, centerY);
+            }
+            else
+            {
+                _glfwGetCursorPosX11(window,
+                                     &_glfw.x11.restoreCursorPosX,
+                                     &_glfw.x11.restoreCursorPosY);
+                _glfwCenterCursorInContentArea(window);
+            }
             if (window->rawMouseMotion)
                 enableRawMouseMotion(window);
         }
